---
import '~/styles/global.css'
import { signInUrl } from '@chirag127/astro-shell/auth-gate'
import { pricingUrl } from '@chirag127/astro-shell/pricing-url'

interface Props {
  title?: string
  description?: string
}

const { title = 'Oriz Universal Converter — Whatever you have. Whatever you need. In your browser.', description = 'Units, currency, timezone, number bases. Live exchange rates. Meeting planner.' } = Astro.props
const canonical = new URL(Astro.url.pathname, 'https://convert.oriz.in').toString()
const pricingHref = pricingUrl('oriz-shift-convert-tools-app')
const signInHref = signInUrl()
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site">
      <a class="wordmark" href="/">Convert</a>
      <nav>
        <a href="/">tools</a>
        <a href="/about/">about</a>
        <a href={pricingHref}>pricing</a>
        <a href={signInHref}>sign in</a>
      </nav>
    </header>
    <main id="main"><slot /></main>
    <footer class="site">
      <span>Oriz Universal Converter · part of the <a href="https://oriz.in">oriz</a> family · runs in your browser</span>
      <span>
        <a href="/about/">about</a> · <a href="/contact/">contact</a> · <a href="/legal/privacy/">privacy</a> · <a href="/legal/terms/">terms</a> · <a href="/legal/disclaimer/">disclaimer</a>
      </span>
    </footer>
  </body>
</html>
